# ==========================================
# Variables de entorno (ejemplo)
# ==========================================
# Copiá este archivo como `.env` y completá los valores:
#   cp .env.example .env
#
# En producción, estas variables se configuran en el panel del
# hosting (Easypanel, Docker, systemd, etc.) o al lanzar el contenedor:
#   docker run -e RESEND_API_KEY=re_xxx ...
#   docker run -e RESEND_FROM_EMAIL=noreply@resend.ipstream.cl ...
#

# Servidor
NODE_ENV=production
PORT=3000

# CORS - orígenes permitidos separados por coma
# Ejemplo: https://mi-radio.cl,https://www.mi-radio.cl
ALLOWED_ORIGINS=https://fusionaustral.ipstream.cl

# ==========================================
# Resend (envío de correos del formulario)
# ==========================================
# API key de Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Email remitente (debe ser de un dominio verificado en Resend)
# Por defecto usa onboarding@resend.dev (solo envía al email de la cuenta)
RESEND_FROM_EMAIL=noreply@resend.ipstream.cl
RESEND_FROM_NAME=Radio Online
